        "name": "fable-lite-before-model",
        "command": "python \"{FABLE_LITE_ROOT}/adapters/antigravity/oma_hook.py\" BeforeModel",
        "timeout": 5000
      }
    ],
    "BeforeTool": [
      {
        "type": "command",
