        "command": "python \"{FABLE_LITE_ROOT}/adapters/antigravity/oma_hook.py\" AfterTool",
        "timeout": 5000
      }
    ],
    "AfterAgent": [
      {
        "type": "command",
        "name": "fable-lite-after-agent",
        "command": "python \"{FABLE_LITE_ROOT}/adapters/antigravity/oma_hook.py\" AfterAgent",
        "timeout": 5000
